# RUN: llc -mtriple=riscv32 -x mir -run-pass=machine-outliner -simplify-mir -verify-machineinstrs < %s \
# RUN: | FileCheck -check-prefixes=RV32I-MO %s
# RUN: llc -mtriple=riscv64 -x mir -run-pass=machine-outliner -simplify-mir -verify-machineinstrs < %s \
# RUN: | FileCheck -check-prefixes=RV64I-MO %s

# Check that outlined functions are fixed up when using LR-save call sites and
# the outlined sequence contains SP-based memory accesses.

---
name:            lr_save_sp_fixup_0
tracksRegLiveness: true
isOutlined: false
body:             |
  bb.0:
    liveins: $x10, $x5

    ; RV32I-MO-LABEL: name: lr_save_sp_fixup_0
    ; RV32I-MO: bb.0:
    ; RV32I-MO:   $x2 = ADDI $x2, -16
    ; RV32I-MO-NEXT: SW{{.*}}$x5, $x2, 12
    ; RV32I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV32I-MO-NEXT: $x5 = LW $x2, 12
    ; RV32I-MO-NEXT: $x2 = ADDI $x2, 16
    ;
    ; RV64I-MO-LABEL: name: lr_save_sp_fixup_0
    ; RV64I-MO: bb.0:
    ; RV64I-MO:   $x2 = ADDI $x2, -16
    ; RV64I-MO-NEXT: SD{{.*}}$x5, $x2, 8
    ; RV64I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV64I-MO-NEXT: $x5 = LD $x2, 8
    ; RV64I-MO-NEXT: $x2 = ADDI $x2, 16

    $x11 = LW $x2, 0
    $x12 = ADDI $x11, 1
    SW $x12, $x2, 4
    $x13 = XOR $x12, $x11
    $x14 = ADD $x13, $x12
    $x15 = SUB $x14, $x11
    $x16 = ORI $x15, 123
    $x17 = SLLI $x16, 2
    $x18 = ADD $x17, $x14
    $x19 = XOR $x18, $x13
    $x20 = AND $x19, $x12
    $x10 = ADD $x20, $x11

    $x10 = ADD $x10, $x5
    PseudoBR %bb.1

  bb.1:
    liveins: $x10
    PseudoRET implicit $x10

...
---
name:            lr_save_sp_fixup_1
tracksRegLiveness: true
isOutlined: false
body:             |
  bb.0:
    liveins: $x10, $x5

    ; RV32I-MO-LABEL: name: lr_save_sp_fixup_1
    ; RV32I-MO: bb.0:
    ; RV32I-MO:   $x2 = ADDI $x2, -16
    ; RV32I-MO-NEXT: SW{{.*}}$x5, $x2, 12
    ; RV32I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV32I-MO-NEXT: $x5 = LW $x2, 12
    ; RV32I-MO-NEXT: $x2 = ADDI $x2, 16
    ;
    ; RV64I-MO-LABEL: name: lr_save_sp_fixup_1
    ; RV64I-MO: bb.0:
    ; RV64I-MO:   $x2 = ADDI $x2, -16
    ; RV64I-MO-NEXT: SD{{.*}}$x5, $x2, 8
    ; RV64I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV64I-MO-NEXT: $x5 = LD $x2, 8
    ; RV64I-MO-NEXT: $x2 = ADDI $x2, 16

    $x11 = LW $x2, 0
    $x12 = ADDI $x11, 1
    SW $x12, $x2, 4
    $x13 = XOR $x12, $x11
    $x14 = ADD $x13, $x12
    $x15 = SUB $x14, $x11
    $x16 = ORI $x15, 123
    $x17 = SLLI $x16, 2
    $x18 = ADD $x17, $x14
    $x19 = XOR $x18, $x13
    $x20 = AND $x19, $x12
    $x10 = ADD $x20, $x11

    $x10 = SUB $x10, $x5
    PseudoBR %bb.1

  bb.1:
    liveins: $x10
    PseudoRET implicit $x10

...

---
name:            lr_save_sp_fixup_2
tracksRegLiveness: true
isOutlined: false
body:             |
  bb.0:
    liveins: $x10, $x5

    ; RV32I-MO-LABEL: name: lr_save_sp_fixup_2
    ; RV32I-MO: bb.0:
    ; RV32I-MO:   $x2 = ADDI $x2, -16
    ; RV32I-MO-NEXT: SW{{.*}}$x5, $x2, 12
    ; RV32I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV32I-MO-NEXT: $x5 = LW $x2, 12
    ; RV32I-MO-NEXT: $x2 = ADDI $x2, 16
    ;
    ; RV64I-MO-LABEL: name: lr_save_sp_fixup_2
    ; RV64I-MO: bb.0:
    ; RV64I-MO:   $x2 = ADDI $x2, -16
    ; RV64I-MO-NEXT: SD{{.*}}$x5, $x2, 8
    ; RV64I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV64I-MO-NEXT: $x5 = LD $x2, 8
    ; RV64I-MO-NEXT: $x2 = ADDI $x2, 16

    $x11 = LW $x2, 0
    $x12 = ADDI $x11, 1
    SW $x12, $x2, 4
    $x13 = XOR $x12, $x11
    $x14 = ADD $x13, $x12
    $x15 = SUB $x14, $x11
    $x16 = ORI $x15, 123
    $x17 = SLLI $x16, 2
    $x18 = ADD $x17, $x14
    $x19 = XOR $x18, $x13
    $x20 = AND $x19, $x12
    $x10 = ADD $x20, $x11

    $x10 = XOR $x10, $x5
    PseudoBR %bb.1

  bb.1:
    liveins: $x10
    PseudoRET implicit $x10

...

# Ensure SP-based accesses in the outlined function are fixed up by +16.
# RV32I-MO-LABEL: name: OUTLINED_FUNCTION_0
# RV32I-MO: $x11 = LW $x2, 16
# RV32I-MO: SW{{.*}}$x12, $x2, 20
# RV64I-MO-LABEL: name: OUTLINED_FUNCTION_0
# RV64I-MO: $x11 = LW $x2, 16
# RV64I-MO: SW{{.*}}$x12, $x2, 20
