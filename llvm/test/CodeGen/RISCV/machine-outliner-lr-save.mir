# RUN: llc -mtriple=riscv32 -x mir -run-pass=machine-outliner -simplify-mir -verify-machineinstrs < %s \
# RUN: | FileCheck -check-prefixes=RV32I-MO %s
# RUN: llc -mtriple=riscv64 -x mir -run-pass=machine-outliner -simplify-mir -verify-machineinstrs < %s \
# RUN: | FileCheck -check-prefixes=RV64I-MO %s

# Check that the machine outliner can preserve the alternate LR register (X5)
# when inserting outlined calls.

---
name:            lr_save_outline_0
tracksRegLiveness: true
isOutlined: false
body:             |
  bb.0:
    liveins: $x10, $x11

    ; RV32I-MO-LABEL: name: lr_save_outline_0
    ; RV32I-MO: bb.0:
    ; RV32I-MO:   $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ;
    ; RV64I-MO-LABEL: name: lr_save_outline_0
    ; RV64I-MO: bb.0:
    ; RV64I-MO:   $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}

    $x11 = ORI $x11, 1023
    $x12 = ADDI $x10, 17
    $x13 = AND $x12, $x11
    $x14 = XOR $x13, $x11
    $x15 = ADD $x14, $x12
    $x16 = SUB $x15, $x13
    $x17 = SLLI $x16, 3
    $x10 = ADD $x17, $x14

    PseudoBR %bb.1

  bb.1:
    liveins: $x10
    PseudoRET implicit $x10

...
---
name:            lr_save_outline_1
tracksRegLiveness: true
isOutlined: false
body:             |
  bb.0:
    liveins: $x10, $x11

    ; RV32I-MO-LABEL: name: lr_save_outline_1
    ; RV32I-MO: bb.0:
    ; RV32I-MO:   $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ;
    ; RV64I-MO-LABEL: name: lr_save_outline_1
    ; RV64I-MO: bb.0:
    ; RV64I-MO:   $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}

    $x11 = ORI $x11, 1023
    $x12 = ADDI $x10, 17
    $x13 = AND $x12, $x11
    $x14 = XOR $x13, $x11
    $x15 = ADD $x14, $x12
    $x16 = SUB $x15, $x13
    $x17 = SLLI $x16, 3
    $x10 = ADD $x17, $x14

    PseudoBR %bb.1

  bb.1:
    liveins: $x10
    PseudoRET implicit $x10

...

---
name:            lr_save_outline_2
tracksRegLiveness: true
isOutlined: false
body:             |
  bb.0:
    liveins: $x10, $x11

    ; RV32I-MO-LABEL: name: lr_save_outline_2
    ; RV32I-MO: bb.0:
    ; RV32I-MO:   $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ;
    ; RV64I-MO-LABEL: name: lr_save_outline_2
    ; RV64I-MO: bb.0:
    ; RV64I-MO:   $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}

    $x11 = ORI $x11, 1023
    $x12 = ADDI $x10, 17
    $x13 = AND $x12, $x11
    $x14 = XOR $x13, $x11
    $x15 = ADD $x14, $x12
    $x16 = SUB $x15, $x13
    $x17 = SLLI $x16, 3
    $x10 = ADD $x17, $x14

    PseudoBR %bb.1

  bb.1:
    liveins: $x10
    PseudoRET implicit $x10

...

---
name:            lr_save_outline_live
tracksRegLiveness: true
isOutlined: false
body:             |
  bb.0:
    liveins: $x10, $x11, $x5

    ; RV32I-MO-LABEL: name: lr_save_outline_live
    ; RV32I-MO: bb.0:
    ; RV32I-MO:   $x2 = ADDI $x2, -16
    ; RV32I-MO-NEXT: SW{{.*}}$x5, $x2, 12
    ; RV32I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV32I-MO-NEXT: $x5 = LW $x2, 12
    ; RV32I-MO-NEXT: $x2 = ADDI $x2, 16
    ;
    ; RV64I-MO-LABEL: name: lr_save_outline_live
    ; RV64I-MO: bb.0:
    ; RV64I-MO:   $x2 = ADDI $x2, -16
    ; RV64I-MO-NEXT: SD{{.*}}$x5, $x2, 8
    ; RV64I-MO-NEXT: $x5 = PseudoCALLReg target-flags(riscv-call) @OUTLINED_FUNCTION_0{{.*}}
    ; RV64I-MO-NEXT: $x5 = LD $x2, 8
    ; RV64I-MO-NEXT: $x2 = ADDI $x2, 16

    $x11 = ORI $x11, 1023
    $x12 = ADDI $x10, 17
    $x13 = AND $x12, $x11
    $x14 = XOR $x13, $x11
    $x15 = ADD $x14, $x12
    $x16 = SUB $x15, $x13
    $x17 = SLLI $x16, 3
    $x10 = ADD $x17, $x14

    $x10 = ADD $x10, $x5
    PseudoBR %bb.1

  bb.1:
    liveins: $x10
    PseudoRET implicit $x10

...

# Ensure the outlined function returns via X5.
# RV32I-MO-LABEL: name: OUTLINED_FUNCTION_0
# RV32I-MO: isOutlined: true
# RV32I-MO: JALR
# RV64I-MO-LABEL: name: OUTLINED_FUNCTION_0
# RV64I-MO: isOutlined: true
# RV64I-MO: JALR
