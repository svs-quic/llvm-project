XFAIL:*
# This test fails on LLD since local symbols section dont contain the input file info
# Check that locals in LTO match the correct linker script rules
# based on their original files.
RUN: %clang %clangopts -c -flto -ffunction-sections %p/Inputs/A.c -o %tA.o
RUN: %clang %clangopts -c -ffunction-sections %p/Inputs/B.c -o %tB.o
RUN: %link %linkopts -Map=%t.map.txt -T %p/Inputs/script.t %tA.o %tB.o -o %t.out 
RUN: %filecheck %s --check-prefix=MAP < %t.map.txt

#MAP: .foo
#MAP: __foo_A
#MAP: .text.Afun2
#MAP: .text.Afun1
#MAP: __foo_B
#MAP: .text.Bfun2
#MAP: .text.Bfun1
#MAP: .text.main
#MAP: __foo_end

