#---LTOAsmAlias.test-------------------------------- Executable,LTO ---------------------#
# JIRA : https://jira-quic.qualcomm.com/jira/browse/QTOOL-30716
#BEGIN_COMMENT
# This tests that LTO with linker scripts is able to handle inputs correctly which define
# aliases in module-level inline assembly.
#END_COMMENT

RUN: %clang %clangopts -c %p/Inputs/1.c -ffunction-sections -flto -o %t1.1.o
RUN: %clang %clangopts -c %p/Inputs/2.c -ffunction-sections -o %t1.2.o
RUN: %link %linkopts --gc-sections  -e main  -T %p/Inputs/script.t %t1.1.o %t1.2.o -o %t1.out

RUN: %readelf -S -W %t1.out | %filecheck --check-prefix=SECTIONS %s

SECTIONS: foo
SECTIONS-NOT: ] .text

RUN: %readelf -s -W %t1.out | %filecheck %s

CHECK-DAG: FUNC GLOBAL DEFAULT {{.*}} foo
CHECK-DAG: FUNC GLOBAL DEFAULT {{.*}} alias_foo
CHECK-DAG: FUNC GLOBAL DEFAULT {{.*}} main
