# REQUIRES: x86
# XFAIL: *
# This test fails with lld since it does not set llvm::lto::SymbolResolution::VisibleToRegularObj
# for symbols that need to be kept.

# RUN: rm -rf %t && split-file %s %t
# RUN: llvm-as %t/1.ll -o %t/1.o
# RUN: ld.lld -m elf_x86_64 --lto-linker-scripts %t/1.o -T %t/script.t -o %t/out -e main
# RUN: llvm-readelf -s %t/out | FileCheck --check-prefix=KEEP %s

# KEEP: foo

#--- 1.ll
target datalayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128"
target triple = "x86_64-unknown-linux-gnu"

@data = internal global i32 10
@foo = internal global i32 20, section ".text.foo"

define i32 @main() {
  %a = load i32, ptr @foo
  %b = load i32, ptr @data
  %c = add i32 %a, %b
  ret i32 %c
}

#--- script.t
SECTIONS {
.mytext : { KEEP(*(.text.foo)) }
}
