XFAIL:*
# This test fails with lld since it does not set the appropriate structure (llvm::lto::SymbolResolution)
# VisibleToRegularObj to true for the symbols that need to be kept.
#---LTOKeepSymbol.test-------------------------------- Executable,LTO,LS ---------------------#
# JIRA : https://jira-quic.qualcomm.com/jira/browse/QTOOL-34978
#BEGIN_COMMENT
# Some symbols are not kept, and produces really vague errors.
#END_COMMENT

RUN: %clang %clangopts -fno-pie -c %p/Inputs/1.c -ffunction-sections -o %t1.1.o -flto
RUN: %link %linkopts %t1.1.o -plugin-opt=-function-sections -Map=%t1.map.txt -T %p/Inputs/script.t -o %t2.out
RUN: %filecheck %s -check-prefix=KEEP < %t1.map.txt

