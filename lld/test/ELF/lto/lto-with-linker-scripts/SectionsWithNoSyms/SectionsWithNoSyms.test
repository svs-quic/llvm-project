RUN: %clang %clangopts %clangg0opts -c -flto -fdata-sections -ffunction-sections  %p/Inputs/1.c -o %t1.o
RUN: %link %linkopts %linkg0opts -e main -T %p/Inputs/script.t -plugin-opt=O0 -plugin-opt=-data-sections -plugin-opt=-function-sections  %t1.o -o %t.out
